chatAttachmentInput.addEventListener('change', async (e) => {
    const file = e.target.files[0];
    if(!file) return;

    if(file.size > 200 * 1024 * 1024) {
        alert("ဖိုင်အရွယ်အစား 200MB ထက်မကျော်ရပါ။");
        chatAttachmentInput.value = '';
        return;
    }

    try {
        const base64 = await fileToBase64(file);
        currentAttachment = { mimeType: file.type, data: base64 };

        let mediaHtml = '';
        if(file.type.startsWith('image/')) {
            mediaHtml = `<img src="data:${file.type};base64,${base64}" class="h-14 w-14 object-cover rounded-lg border border-slate-300 shadow-sm">`;
        } else if(file.type.startsWith('video/')) {
