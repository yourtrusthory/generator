function linkifyText(text) {
    const urlRegex = /(https?:\/\/[^\s]+)/g;
    return text.replace(urlRegex, function(url) {
        return `<a href="${url}" target="_blank" class="underline font-medium hover:opacity-80 transition-opacity break-all">${url}</a>`;
    });
}

function extractTextFromParts(parts) {
    return parts.map(p => p.text || "").join("").trim();
}

function renderChatLog() {
    chatLog.innerHTML = '';
    
    if(currentChatHistory.length === 0) {
        chatLog.innerHTML = `<div class="flex w-full justify-start">
            <div class="max-w-[80%] px-5 py-3 rounded-2xl bg-white text-slate-800 border border-slate-200 rounded-bl-none shadow-sm leading-relaxed text-[15px]">
                မင်္ဂလာပါ။ ဘယ်ဘက်တွင် အချက်အလက်များဖြည့်ပြီး စတင် စကားပြောဆိုနိုင်ပါသည်။ 📎 ခလုတ်ကိုနှိပ်၍ ဓာတ်ပုံ သို့မဟုတ် ဗီဒီယို (200MB အထိ) များလည်း ပို့နိုင်ပါသည်။
            </div>
        </div>`;
        return;
    }

    currentChatHistory.forEach((msg, index) => {
        const isUser = msg.role === 'user';
        const div = document.createElement('div');
        div.className = `flex w-full msg-bubble group ${isUser ? 'justify-end' : 'justify-start'}`;
        
        const rawText = extractTextFromParts(msg.parts);
        let formattedText = rawText ? rawText.replace(/\n/g, '<br>') : '';
        formattedText = linkifyText(formattedText);

        // Check for media in history
        let mediaHtml = '';
        msg.parts.forEach(p => {
            if(p.inlineData) {
                if(p.inlineData.mimeType.startsWith('image/')) {
                    mediaHtml += `<div class="mb-2"><img src="data:${p.inlineData.mimeType};base64,${p.inlineData.data}" class="max-h-60 rounded-lg shadow-sm border border-white/20 object-contain"></div>`;
                } else if(p.inlineData.mimeType.startsWith('video/')) {
                    mediaHtml += `<div class="mb-2"><video src="data:${p.inlineData.mimeType};base64,${p.inlineData.data}" controls class="max-h-60 rounded-lg shadow-sm border border-white/20 object-contain"></video></div>`;
                }
            }
        });

        // HTML construction with Edit button for user messages
        let innerContent = '';
        if(isUser) {
            innerContent = `
                <div class="flex items-center gap-2 max-w-[85%]">
                    <button onclick="window.openEditModal(${index})" class="edit-btn hidden p-1.5 bg-slate-200 text-slate-600 rounded-full hover:bg-slate-300 transition-colors shadow-sm" title="စာပြင်မည်">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
                    </button>
                    <div class="px-5 py-3 rounded-2xl leading-relaxed text-[15px] bg-gradient-to-br from-indigo-600 to-indigo-700 text-white rounded-br-none shadow-md border border-indigo-500 overflow-hidden break-words">
                        ${mediaHtml}
                        ${formattedText}
                    </div>
                </div>
            `;
        } else {
            innerContent = `
                <div class="flex flex-col gap-1 max-w-[85%]">
                    <div class="px-5 py-3 rounded-2xl leading-relaxed text-[15px] bg-white text-slate-800 border border-slate-200 rounded-bl-none shadow-sm overflow-hidden break-words">
                        ${mediaHtml}
                        ${formattedText}
                    </div>
                    <button onclick="window.playTTS(${index}, this)" class="self-start text-[11px] text-slate-500 hover:text-indigo-600 flex items-center gap-1 px-2 py-1 bg-slate-100 rounded-lg transition-colors border border-slate-200 shadow-sm mt-1">
                        ✨ 🔊 အသံဖြင့်နားထောင်မည်
                    </button>
                    ${index === currentChatHistory.length - 1 ? `
                    <button onclick="window.regenerateMessage()" class="self-start text-[11px] text-slate-500 hover:text-amber-600 flex items-center gap-1 px-2 py-1 bg-slate-100 rounded-lg transition-colors border border-slate-200 shadow-sm mt-1">
                        🔄 အခြားပုံစံဖြင့် ပြန်ပြောမည်
                    </button>
                    ` : ''}
                </div>
            `;
        }

        div.innerHTML = innerContent;
        chatLog.appendChild(div);
    });
    
