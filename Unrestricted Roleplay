avatarContainer.onclick = () => charAvatarInput.click();

charAvatarInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if(!file) return;

    const reader = new FileReader();
    reader.onload = function(event) {
        const img = new Image();
        img.onload = function() {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            
            let size = 200; // Resize to save database space
            let minDim = Math.min(img.width, img.height);
            let sx = (img.width - minDim) / 2;
            let sy = (img.height - minDim) / 2;

            canvas.width = size;
            canvas.height = size;
            ctx.drawImage(img, sx, sy, minDim, minDim, 0, 0, size, size);
            
            currentAvatarBase64 = canvas.toDataURL('image/jpeg', 0.8);
            updateAvatarUI(currentAvatarBase64);
            scheduleAutoSave(); 
        }
        img.src = event.target.result;
    }
    reader.readAsDataURL(file);
});

function updateAvatarUI(base64Str) {
    if(base64Str) {
        charAvatarPreview.src = base64Str;
        charAvatarPreview.classList.remove('hidden');
        charAvatarPlaceholder.classList.add('hidden');
        chatHeaderAvatar.src = base64Str;
        chatHeaderAvatar.classList.remove('hidden');
    } else {
        charAvatarPreview.src = '';
        charAvatarPreview.classList.add('hidden');
        charAvatarPlaceholder.classList.remove('hidden');
        chatHeaderAvatar.src = '';
        chatHeaderAvatar.classList.add('hidden');
    }
}

// --- Auth Setup ---
