function renderCharacterList() {
    characterListEl.innerHTML = '';
    if(charactersList.length === 0) {
        characterListEl.innerHTML = '<div class="text-xs text-slate-400 italic py-2 text-center">ဇာတ်ကောင် မရှိသေးပါ</div>';
        return;
    }

    charactersList.forEach(char => {
        const btn = document.createElement('div');
        const isSelected = char.id === currentCharId;
        btn.className = `flex justify-start items-center gap-3 px-3 py-2 rounded-xl cursor-pointer border transition-colors ${isSelected ? 'bg-indigo-50 border-indigo-200 text-indigo-700' : 'bg-slate-50 border-transparent hover:bg-slate-100 text-slate-700'}`;
        
        let avatarHtml = `<div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-slate-400 flex-shrink-0 text-xs shadow-inner">👤</div>`;
        if(char.avatar) {
            avatarHtml = `<img src="${char.avatar}" class="w-8 h-8 rounded-full object-cover flex-shrink-0 border border-slate-200 shadow-sm">`;
        }

        const nameSpan = document.createElement('span');
        nameSpan.className = "font-medium text-sm truncate flex-grow";
        nameSpan.innerText = char.name || "အမည်မသိ";
        
        btn.onclick = () => selectCharacter(char.id);
        
        btn.innerHTML = avatarHtml;
        btn.appendChild(nameSpan);
        characterListEl.appendChild(btn);
    });
}

function createNewCharacter() {
    currentCharId = crypto.randomUUID();
    charNameInput.value = "";
    charDescInput.value = "";
    charInstructionsInput.value = "";
    currentChatHistory = [];
    currentAvatarBase64 = null;
    updateAvatarUI(null);
    chatHeaderName.innerText = `စကားပြောခန်း အသစ်`;
    
    // Add to list virtually
    const newChar = { id: currentCharId, name: "ဇာတ်ကောင်သစ်", desc: "", instructions: "", avatar: null, history: [], updatedAt: Date.now() };
    charactersList.unshift(newChar);
    
    renderCharacterList();
    renderChatLog();
    scheduleAutoSave();
    saveCurrentCharacterToCloud(); // Auto save immediately upon creation
}

createNewCharBtn.onclick = createNewCharacter;

function selectCharacter(id) {
    currentCharId = id;
    const char = charactersList.find(c => c.id === id);
    if(char) {
        charNameInput.value = char.name || "";
        charDescInput.value = char.desc || "";
        charInstructionsInput.value = char.instructions || "";
        currentChatHistory = char.history || [];
        currentAvatarBase64 = char.avatar || null;
        updateAvatarUI(currentAvatarBase64);
        chatHeaderName.innerText = `${char.name || 'စကားပြောခန်း'}`;
    }
    renderCharacterList(); // update active state
    renderChatLog();
}

async function saveCurrentCharacterToCloud() {
    if(!currentUser || !currentCharId) return;
    syncStatus.innerText = "☁️ သိမ်းနေသည်...";
    try {
        const charRef = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'characters', currentCharId);
        
        // Prevent DB size bloat & 1MB limit crash, but allow small images (< 700KB)
        const cleanHistory = currentChatHistory.map(msg => {
            if(msg.role === 'user') {
                return {
                    ...msg,
                    parts: msg.parts.map(p => {
                        if (p.inlineData) {
                            if (p.inlineData.data.length < 700000) { 
                                return p; // Save small media to cloud
                            } else {
                                return { text: "\n[ကြီးမားသော မီဒီယာဖိုင်တစ်ခု ပို့ခဲ့သည် - Database Limit ကြောင့် မသိမ်းပါ]" };
                            }
                        }
                        return p;
                    })
                };
            }
            return msg;
        });

        const charData = {
            name: charNameInput.value,
            desc: charDescInput.value,
            instructions: charInstructionsInput.value,
            avatar: currentAvatarBase64,
            history: cleanHistory,
            updatedAt: Date.now()
        };

        await setDoc(charRef, charData, { merge: true });
        
        // Update local list silently
        const listIdx = charactersList.findIndex(c => c.id === currentCharId);
        if(listIdx !== -1) {
            charactersList[listIdx].name = charData.name;
            charactersList[listIdx].desc = charData.desc;
            charactersList[listIdx].instructions = charData.instructions;
            charactersList[listIdx].avatar = charData.avatar;
            charactersList[listIdx].history = cleanHistory;
        }
        chatHeaderName.innerText = `${charData.name || 'စကားပြောခန်း'}`;
        renderCharacterList();
        
