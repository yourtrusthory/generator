}

// Global hook for edit button
window.openEditModal = function(index) {
    editingMsgIndex = index;
    const msg = currentChatHistory[index];
    const rawText = extractTextFromParts(msg.parts);
    
    // Clean up media placeholders if it exists from db load
    let textToEdit = rawText.replace("\n[မီဒီယာဖိုင်တစ်ခု ပို့ခဲ့သည်]", "").trim();
    textToEdit = textToEdit.replace("\n[ကြီးမားသော မီဒီယာဖိုင်တစ်ခု ပို့ခဲ့သည် - Database Limit ကြောင့် မသိမ်းပါ]", "").trim();
    
    editMsgInput.value = textToEdit;
    editModal.classList.remove('hidden');
    editModal.classList.add('flex');
    editMsgInput.focus();
}

cancelEditBtn.onclick = () => {
    editModal.classList.add('hidden');
    editModal.classList.remove('flex');
    editingMsgIndex = -1;
};

saveEditBtn.onclick = () => {
    if(editingMsgIndex > -1) {
        const newText = editMsgInput.value.trim();
        if(newText) {
            // Only update text part, preserve inlineData if any locally
            const oldParts = currentChatHistory[editingMsgIndex].parts;
            const updatedParts = oldParts.map(p => p.inlineData ? p : { text: newText });
            
            // If there was no text part but now there is
            if(!updatedParts.find(p => p.text)) {
                updatedParts.push({ text: newText });
            }

            currentChatHistory[editingMsgIndex].parts = updatedParts;
            renderChatLog();
            saveCurrentCharacterToCloud();
        }
    }
    cancelEditBtn.click();
};


