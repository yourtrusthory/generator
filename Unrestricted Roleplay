};

initAuth();

onAuthStateChanged(auth, async (user) => {
    if(user) {
        currentUser = user;
        syncStatus.innerText = "☁️ ဆွဲယူနေသည်...";
        await loadUserPersona();
        await loadAllCharacters();
        syncStatus.innerText = "☁️ Cloud တွင် သိမ်းဆည်းထားပါသည်";
