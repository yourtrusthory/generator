// --- Database Logic ---

async function loadUserPersona() {
    if(!currentUser) return;
    try {
        const docRef = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'settings', 'persona');
        const snap = await getDoc(docRef);
        if(snap.exists()) {
            userPersonaInput.value = snap.data().text || "";
        }
    } catch(e) {
        console.error("Error loading user persona", e);
    }
}

async function saveUserPersonaToCloud() {
    if(!currentUser) return;
    try {
        const docRef = doc(db, 'artifacts', appId, 'users', currentUser.uid, 'settings', 'persona');
        await setDoc(docRef, { text: userPersonaInput.value }, { merge: true });
        userPersonaSavedStatus.classList.remove('hidden');
        userPersonaSavedStatus.classList.add('flex');
        setTimeout(() => {
            userPersonaSavedStatus.classList.add('hidden');
            userPersonaSavedStatus.classList.remove('flex');
        }, 2000);
    } catch(e) {
        console.error("Error saving user persona", e);
    }
}

let userPersonaAutoSaveTimeout;
userPersonaInput.addEventListener('input', () => {
    clearTimeout(userPersonaAutoSaveTimeout);
    userPersonaAutoSaveTimeout = setTimeout(saveUserPersonaToCloud, 1500);
});

async function loadAllCharacters() {
    if(!currentUser) return;
    try {
        const charsRef = collection(db, 'artifacts', appId, 'users', currentUser.uid, 'characters');
        const snapshot = await getDocs(charsRef);
        
        charactersList = [];
        snapshot.forEach(doc => {
            charactersList.push({ id: doc.id, ...doc.data() });
        });
        
        // Sort by updatedAt (descending)
        charactersList.sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));

        renderCharacterList();

        if(charactersList.length > 0) {
            selectCharacter(charactersList[0].id);
        } else {
            await seedDefaultCharacters();
        }
    } catch(e) {
        syncStatus.innerText = "⚠️ ဒေတာများ ဆွဲယူရန် မအောင်မြင်ပါ";
